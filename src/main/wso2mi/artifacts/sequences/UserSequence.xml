<?xml version="1.0" encoding="UTF-8"?>

<sequence xmlns="http://ws.apache.org/ns/synapse"
  name="UserSequence">

  <property name="id" expression="get-property('uri.var.id')"/>

  <filter source="boolean(get-property('id'))" regex="true">

    <then>
      <call>
        <endpoint>
          <http method="GET"
            uri-template="http://localhost:8290/services/UserService/user/{uri.var.id}"/>
        </endpoint>
      </call>
    </then>

    <else>
      <call>
        <endpoint>
          <http method="GET"
            uri-template="http://localhost:8290/services/UserService/users"/>
        </endpoint>
      </call>
    </else>

  </filter>

  <respond/>

</sequence>