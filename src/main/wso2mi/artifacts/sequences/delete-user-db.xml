<sequence name="delete-user-db" xmlns="http://ws.apache.org/ns/synapse">

  <dbreport>
    <connection>
      <pool>
        <driver>com.mysql.cj.jdbc.Driver</driver>
        <url>jdbc:mysql://host.docker.internal:3306/testdb</url>
        <user>root</user>
        <password>123456</password>
      </pool>
    </connection>

    <statement>
      <sql>DELETE FROM users WHERE id=?</sql>
      <parameter expression="get-property('id')" type="INTEGER"/>
    </statement>
  </dbreport>

</sequence>